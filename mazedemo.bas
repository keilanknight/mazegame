10 REM RANDOM MAZE DEMONSTRATION
20 BORDER 0: PAPER 0: INK 7: BRIGHT 0: FLASH 0: CLS
30 LET W$=CHR$ 134
40 LET H=6: LET M=9
50 LET D=12
60 GO SUB 1000
70 GO SUB 2000
80 GO TO 3000

1000 REM FIRST EXPLANATION SCREEN
1010 CLS
1020 INK 6
1030 PRINT AT 1,4;"HOW A RANDOM MAZE IS MADE"
1040 INK 7
1050 PRINT AT 4,1;"WE BEGIN WITH SOLID ROCK."
1060 PRINT AT 6,1;"AN EXPLORER DIGS FROM CELL"
1070 PRINT AT 7,1;"TO CELL."
1080 PRINT AT 9,1;"IT ONLY ENTERS CELLS WHICH"
1090 PRINT AT 10,1;"HAVE NOT BEEN VISITED."
1100 PRINT AT 13,1;"WHEN IT HAS SEVERAL ROUTES,"
1110 PRINT AT 14,1;"IT CHOOSES ONE AT RANDOM."
1120 PRINT AT 19,4;"PRESS ANY KEY"
1130 PAUSE 0
1140 RETURN

2000 REM SECOND EXPLANATION SCREEN
2010 CLS
2020 INK 6
2030 PRINT AT 1,7;"WHEN IT GETS STUCK"
2040 INK 7
2050 PRINT AT 4,1;"THE EXPLORER RETRACES ITS"
2060 PRINT AT 5,1;"STEPS UNTIL IT FINDS AN"
2070 PRINT AT 6,1;"UNEXPLORED ROUTE."
2080 PRINT AT 9,1;INK 6;"F";INK 7;" = DIGGING FORWARD"
2090 PRINT AT 11,1;INK 3;".";INK 7;" = VISITED CELL"
2100 PRINT AT 13,1;INK 5;"B";INK 7;" = BACKTRACKING"
2110 PRINT AT 16,1;"THE ROUTE IS REMEMBERED IN"
2120 PRINT AT 17,1;"A LIST CALLED A STACK."
2130 PRINT AT 20,4;"PRESS ANY KEY TO BEGIN"
2140 PAUSE 0
2150 RETURN

3000 REM CREATE THE ARRAYS
3010 DIM V(H,M)
3020 DIM R(H*M)
3030 DIM C(H*M)
3040 DIM A(4)
3050 DIM Y(4)
3060 DIM X(4)

3100 REM DIRECTION 1 IS RIGHT
3110 LET Y(1)=0: LET X(1)=1
3120 REM DIRECTION 2 IS LEFT
3130 LET Y(2)=0: LET X(2)=-1
3140 REM DIRECTION 3 IS DOWN
3150 LET Y(3)=1: LET X(3)=0
3160 REM DIRECTION 4 IS UP
3170 LET Y(4)=-1: LET X(4)=0

3200 RANDOMIZE
3210 GO SUB 4000
3220 GO SUB 5000
3230 GO TO 6000

4000 REM DRAW A SOLID BLOCK OF ROCK
4010 CLS
4020 INK 1
4030 FOR I=0 TO H*2
4040 FOR J=0 TO M*2
4050 PRINT AT I,J;W$
4060 NEXT J
4070 NEXT I

4080 REM INFORMATION PANEL
4090 INK 7
4100 PRINT AT 0,22;"MAZE DEMO"
4110 PRINT AT 2,20;"MODE:"
4120 PRINT AT 5,20;"CELL:"
4130 PRINT AT 8,20;"DEPTH:"
4140 PRINT AT 11,20;"EXITS:"
4150 PRINT AT 15,20;INK 6;"F = FORWARD"
4160 PRINT AT 17,20;INK 5;"B = BACK"
4170 PRINT AT 19,20;INK 3;". = VISITED"
4180 RETURN

5000 REM CLEAR THE VISITED MAP
5010 FOR I=1 TO H
5020 FOR J=1 TO M
5030 LET V(I,J)=0
5040 NEXT J
5050 NEXT I

5100 REM START IN THE BOTTOM LEFT
5110 LET S=1
5120 LET R(1)=H
5130 LET C(1)=1
5140 LET V(H,1)=1
5150 LET P=H*2-1
5160 LET Q=1
5165 LET CR=H: LET CC=1
5170 PRINT AT P,Q;INK 6;"F"
5180 GO SUB 9000
5190 RETURN

6000 REM READ THE CURRENT CELL FROM THE STACK
6010 LET CR=R(S)
6020 LET CC=C(S)
6030 LET N=0

6100 REM CHECK ALL FOUR DIRECTIONS
6110 FOR K=1 TO 4
6120 LET NR=CR+Y(K)
6130 LET NC=CC+X(K)

6140 REM IS THE NEIGHBOUR INSIDE THE MAZE?
6150 IF NR<1 OR NR>H OR NC<1 OR NC>M THEN GO TO 6200

6160 REM HAS THE NEIGHBOUR BEEN VISITED?
6170 IF V(NR,NC)=1 THEN GO TO 6200

6180 REM REMEMBER THIS AVAILABLE DIRECTION
6190 LET N=N+1: LET A(N)=K

6200 NEXT K
6210 GO SUB 9200

6300 REM NO CHOICES MEANS A DEAD END
6310 IF N=0 THEN GO TO 7000

6400 REM CHOOSE ONE AVAILABLE ROUTE AT RANDOM
6410 LET Z=INT (RND*N)+1
6420 LET K=A(Z)
6430 LET NR=CR+Y(K)
6440 LET NC=CC+X(K)

6500 REM CHANGE OLD FORWARD MARKER TO A DOT
6510 PRINT AT CR*2-1,CC*2-1;INK 3;"."

6520 REM REMOVE THE WALL BETWEEN THE CELLS
6530 LET WY=CR*2-1+Y(K)
6540 LET WX=CC*2-1+X(K)
6550 PRINT AT WY,WX;" "

6560 REM OPEN AND ENTER THE NEW CELL
6570 PRINT AT NR*2-1,NC*2-1;" "
6580 LET V(NR,NC)=1

6600 REM ADD THE NEW CELL TO THE STACK
6610 LET S=S+1
6620 LET R(S)=NR
6630 LET C(S)=NC

6640 REM SHOW THE EXPLORER MOVING FORWARD
6650 PRINT AT NR*2-1,NC*2-1;INK 6;"F"
6660 GO SUB 9000
6670 PAUSE D
6680 GO TO 6000

7000 REM THE CURRENT CELL IS A DEAD END
7010 PRINT AT CR*2-1,CC*2-1;INK 5;"B"
7020 GO SUB 9100
7030 PAUSE D

7040 REM ARE WE BACK AT THE START?
7050 IF S=1 THEN GO TO 8000

7060 REM LEAVE A VISITED DOT BEHIND
7070 PRINT AT CR*2-1,CC*2-1;INK 3;"."

7080 REM MOVE BACK ONE PLACE IN THE STACK
7090 LET S=S-1
7100 LET CR=R(S)
7110 LET CC=C(S)

7120 REM SHOW THE CELL WE HAVE RETURNED TO
7130 PRINT AT CR*2-1,CC*2-1;INK 5;"B"
7140 GO SUB 9100
7150 PAUSE D
7160 GO TO 6000

8000 REM MAZE COMPLETE
8010 PRINT AT CR*2-1,CC*2-1;" "
8020 LET L=2: GO SUB 9300
8025 PRINT AT 2,19;INK 4;"  COMPLETE "
8030 LET L=5: GO SUB 9300
8040 LET L=8: GO SUB 9300
8050 LET L=11: GO SUB 9300

8060 REM REMOVE THE VISITED DOTS
8070 FOR I=1 TO H
8080 FOR J=1 TO M
8090 IF V(I,J)=1 THEN PRINT AT I*2-1,J*2-1;" "
8100 NEXT J
8110 NEXT I

8120 BEEP .05,5
8130 BEEP .05,9
8140 BEEP .05,12
8150 PRINT AT 15,19;INK 6;" FINISHED!  "
8160 PRINT AT 17,19;INK 7;" EVERY CELL "
8170 PRINT AT 18,19;INK 7;" WAS VISITED"
8170 PRINT AT 19,19;INK 7;"            "
8180 PRINT AT 20,19;INK 3;" PRESS A KEY"
8190 PAUSE 0
8200 RUN

9000 REM DISPLAY FORWARD INFORMATION
9005 LET L=2: GO SUB 9350
9010 PRINT AT 2,26;INK 6;"FWD "
9015 LET L=5: GO SUB 9350
9020 PRINT AT 5,26;INK 7;STR$ CR;",";STR$ CC
9025 LET L=8: GO SUB 9350
9030 PRINT AT 8,26;INK 7;STR$ S
9040 RETURN

9100 REM DISPLAY BACKTRACK INFORMATION
9105 LET L=2: GO SUB 9350
9110 PRINT AT 2,26;INK 5;"BACK"
9115 LET L=5: GO SUB 9350
9120 PRINT AT 5,26;INK 7;STR$ CR;",";STR$ CC
9125 LET L=8: GO SUB 9350
9130 PRINT AT 8,26;INK 7;STR$ S
9140 RETURN

9200 REM DISPLAY NUMBER OF AVAILABLE ROUTES
9205 LET L=11: GO SUB 9350
9210 PRINT AT 11,26;INK 7;STR$ N
9220 RETURN

9300 REM CLEAR A WHOLE INFORMATION LINE
9310 PRINT AT L,20;"           "
9320 RETURN

9350 REM CLEAR A FIVE CHARACTER VALUE FIELD
9360 PRINT AT L,26;"     "
9370 RETURN
